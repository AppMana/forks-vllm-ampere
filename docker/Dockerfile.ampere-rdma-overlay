ARG BASE_IMAGE=harbor.appmana.com/appmana/vllm-ampere:nccl2304-socket-base-7c5968b72-20260608
FROM ${BASE_IMAGE}

ARG NCCL_PACKAGE_VERSION=
ARG USB4_RDMA_PROVIDER_VERSION=0.2.1

USER root

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN set -eux; \
    export DEBIAN_FRONTEND=noninteractive; \
    apt-get update; \
    if [[ -n "${NCCL_PACKAGE_VERSION}" ]]; then \
      apt-get install -y --no-install-recommends \
        "libnccl2=${NCCL_PACKAGE_VERSION}" \
        "libnccl-dev=${NCCL_PACKAGE_VERSION}"; \
    fi; \
    apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      ibverbs-utils \
      libibverbs1 \
      perftest \
      rdma-core; \
    . /etc/os-release; \
    curl -fsSL -o /tmp/usb4-rdma-provider.deb \
      "https://github.com/hellas-ai/thunderbolt-ibverbs/releases/download/v${USB4_RDMA_PROVIDER_VERSION}/usb4-rdma-provider_${USB4_RDMA_PROVIDER_VERSION}.${VERSION_CODENAME}_amd64.deb"; \
    apt-get install -y --no-install-recommends /tmp/usb4-rdma-provider.deb; \
    rm -f /tmp/usb4-rdma-provider.deb; \
    rm -rf /var/lib/apt/lists/*
