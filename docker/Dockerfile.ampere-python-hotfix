# Minimal Python hotfix overlay for Ampere vLLM serving images.
#
# Use this for a narrowly scoped Python patch when the base image already
# contains the desired wheel, package metadata, and native extensions.

ARG BASE_IMAGE=harbor.appmana.com/appmana/vllm-ampere:latest
ARG PYTHON_VERSION=3.12

FROM ${BASE_IMAGE}

ARG PYTHON_VERSION

COPY vllm/v1/core/single_type_kv_cache_manager.py /usr/local/lib/python${PYTHON_VERSION}/dist-packages/vllm/v1/core/single_type_kv_cache_manager.py
COPY vllm/envs.py /usr/local/lib/python${PYTHON_VERSION}/dist-packages/vllm/envs.py
COPY vllm/model_executor/warmup/deepseek_v4_mhc_warmup.py /usr/local/lib/python${PYTHON_VERSION}/dist-packages/vllm/model_executor/warmup/deepseek_v4_mhc_warmup.py
COPY vllm/model_executor/warmup/kernel_warmup.py /usr/local/lib/python${PYTHON_VERSION}/dist-packages/vllm/model_executor/warmup/kernel_warmup.py
COPY vllm/models/deepseek_v4/nvidia/mtp.py /usr/local/lib/python${PYTHON_VERSION}/dist-packages/vllm/models/deepseek_v4/nvidia/mtp.py
COPY vllm/v1/worker/gpu_worker.py /usr/local/lib/python${PYTHON_VERSION}/dist-packages/vllm/v1/worker/gpu_worker.py
